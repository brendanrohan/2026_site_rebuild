---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>

	<!-- Header -->
	<header class="px-8 py-6">
		<!-- Top row: Logo/Name, Clock (centered), and Navigation -->
		<div class="relative flex items-center justify-between mb-12">
			<!-- Left: Wave + Name -->
			<div class="flex items-center gap-3">
				<span class="text-2xl">👋</span>
				<span class="text-base font-semibold text-gray-900">Hi, I'm Brendan</span>
			</div>

			<!-- Center: NY Clock -->
			<div class="absolute left-1/2 -translate-x-1/2 flex items-center gap-2 text-sm text-gray-900">
				<!-- Sun icon (daytime) -->
				<svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
				</svg>
				<!-- Moon icon (nighttime) -->
				<svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
				</svg>
				<span>NY</span>
				<span id="ny-time">--:--:-- --</span>
			</div>

			<!-- Right: Navigation -->
			<nav class="flex gap-4 text-sm text-gray-900">
				<a href="#work" class="hover:opacity-70 transition-opacity">Work</a>
				<span class="text-gray-400">,</span>
				<a href="/about" class="hover:opacity-70 transition-opacity">About</a>
			</nav>
		</div>

		<!-- Bio section with profile image -->
		<div class="flex items-start gap-12 ml-[92px]">
			<!-- Bio text -->
			<div class="max-w-md">
				<p class="text-base text-gray-700 mb-4">
					I'm a <strong>UX designer</strong> that helps organizations turn emerging technology into experiences people actually use.
				</p>
				<p class="text-base text-gray-600 mb-8">
					I've spent 15 years figuring out what new technology means for the people who use it, and for the organizations that need to deliver it.
				</p>
				<a
					href="/Brendan_Rohan_Resume_2026.pdf"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2 bg-gray-900 text-white text-sm font-medium px-5 py-3 rounded-full hover:bg-gray-700 transition-colors"
				>
					View Resume
					<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
					</svg>
				</a>
			</div>

			<!-- Profile image -->
			<div class="shrink-0">
				<img
					src="/images/profile_sketch_portrait.png"
					alt="Brendan Rohan"
					class="w-40 h-auto object-contain"
				/>
			</div>
		</div>
	</header>

	<script>
		function updateNYClock() {
			const timeEl = document.getElementById('ny-time');
			const sunIcon = document.getElementById('icon-sun');
			const moonIcon = document.getElementById('icon-moon');

			if (!timeEl || !sunIcon || !moonIcon) return;

			// Get current time in New York
			const nyTime = new Date().toLocaleString('en-US', {
				timeZone: 'America/New_York',
				hour: 'numeric',
				minute: '2-digit',
				second: '2-digit',
				hour12: true
			});

			timeEl.textContent = nyTime;

			// Get hour in NY to determine day/night
			const nyHour = parseInt(new Date().toLocaleString('en-US', {
				timeZone: 'America/New_York',
				hour: 'numeric',
				hour12: false
			}));

			// Daytime: 6am - 8pm (6-20)
			const isDaytime = nyHour >= 6 && nyHour < 20;

			if (isDaytime) {
				sunIcon.classList.remove('hidden');
				moonIcon.classList.add('hidden');
			} else {
				sunIcon.classList.add('hidden');
				moonIcon.classList.remove('hidden');
			}
		}

		// Update immediately and then every second
		updateNYClock();
		setInterval(updateNYClock, 1000);
	</script>

	<main class="ml-[92px] pr-8 pt-24">

		<!-- Section: Case Studies -->
		<div class="border-t border-gray-200 mb-12">
			<span class="text-sm text-gray-900 block pt-4">(Case Studies)</span>
		</div>
		<section id="work" class="pb-16 border-b border-gray-200">
			<div class="space-y-24">

				<!-- Project 1: Quiet Signals -->
				<a href="/case-studies/quiet-signals" class="group flex items-center gap-16">
					<div class="flex-1 max-w-md">
						<h3 class="text-3xl font-normal text-gray-900 mb-6">Quiet Signals: designing a caregiver companion that doesn't feel like surveillance.</h3>
						<p class="text-lg text-gray-600 leading-relaxed mb-8">An AI-assisted app that helps adult children sense — gently — whether an aging parent is okay today, without check-ins that strain the relationship.</p>
						<div class="flex gap-6 flex-wrap text-xs tracking-widest uppercase text-gray-400">
							<span>Personal Project</span>
							<span>AI-First Design</span>
							<span>Conversational UX</span>
						</div>
					</div>
					<div class="flex-1 bg-gray-100 rounded-2xl p-8 flex items-center justify-center min-h-80">
						<span class="text-gray-400 text-sm">Image placeholder</span>
					</div>
				</a>

				<!-- Project 2: AT&T -->
				<a href="/case-studies/att-personalized-shopping" class="group flex items-center gap-16">
					<div class="flex-1 max-w-md">
						<h3 class="text-3xl font-normal text-gray-900 mb-6">Personalizing the shopping experience</h3>
						<p class="text-lg text-gray-600 leading-relaxed mb-8">Combined customer intent and data to transform AT&T's shopping experience to better reflect how customers wanted to buy mobile plans and phones.</p>
						<div class="flex gap-6 flex-wrap text-xs tracking-widest uppercase text-gray-400">
							<span>End-to-End</span>
							<span>Personalization</span>
							<span>Generative AI</span>
						</div>
					</div>
					<div class="flex-1 bg-gray-100 rounded-2xl p-8 flex items-center justify-center">
						<img src="/images/att_ShoppersProfile.png" alt="AT&T Shopper Profile" class="max-w-full max-h-80 object-contain group-hover:scale-[1.02] transition-transform duration-300" />
					</div>
				</a>

				<!-- Project 3: Verizon -->
				<a href="/case-studies/verizon-number-transfer" class="group flex items-center gap-16">
					<div class="flex-1 max-w-md">
						<h3 class="text-3xl font-normal text-gray-900 mb-6">A more transparent, omnichannel service experience</h3>
						<p class="text-lg text-gray-600 leading-relaxed mb-8">Transformed a fragmented, opaque process into one that is more transparent and customer-focused across retail, web, app, and IVR channels.</p>
						<div class="flex gap-6 flex-wrap text-xs tracking-widest uppercase text-gray-400">
							<span>Omnichannel</span>
							<span>Service Design</span>
							<span>UX Research</span>
						</div>
					</div>
					<div class="flex-1 bg-gray-100 rounded-2xl p-8 flex items-center justify-center">
						<img src="/images/vz_NumberTransfer.png" alt="Verizon Number Transfer" class="max-w-full max-h-80 object-contain group-hover:scale-[1.02] transition-transform duration-300" />
					</div>
				</a>

				<!-- Project 4: xFinity -->
				<a href="/case-studies/xfi-reimagined" class="group flex items-center gap-16">
					<div class="flex-1 max-w-md">
						<h3 class="text-3xl font-normal text-gray-900 mb-6">xFi, reimagined: what WiFi management looks like when the network can talk back.</h3>
						<p class="text-lg text-gray-600 leading-relaxed mb-8">A speculative redesign of Comcast's xFi platform — exploring how a conversational interface and an agentic layer underneath would change the product I helped ship in 2017.</p>
						<div class="flex gap-6 flex-wrap text-xs tracking-widest uppercase text-gray-400">
							<span>Voice UI</span>
							<span>Conversational Design</span>
							<span>Mobile</span>
						</div>
					</div>
					<div class="flex-1 bg-gray-100 rounded-2xl p-8 flex items-center justify-center">
						<img src="/images/xfi_ConversationalDesign.png" alt="xFinity Conversational Design" class="max-w-full max-h-80 object-contain group-hover:scale-[1.02] transition-transform duration-300" />
					</div>
				</a>

			</div>
		</section>

		<!-- Section: Work History -->
		<div class="border-t border-gray-200 mt-16 mb-12">
			<span class="text-sm text-gray-900 block pt-4">(Work)</span>
		</div>
		<section id="work-history" class="pb-16 border-b border-gray-200">
			<div class="space-y-14">

				<!-- 2026 - Career Break -->
				<div class="grid grid-cols-[1fr_1fr_2fr] gap-12 items-start">
					<div>
						<span class="inline-block bg-gray-200 text-gray-700 text-sm px-4 py-2 rounded-full">2026</span>
					</div>
					<div>
						<h3 class="text-lg font-semibold text-gray-900">Career Break</h3>
						<p class="text-gray-500 italic">Independent Product Work</p>
					</div>
					<div>
						<p class="text-gray-600 mb-3">Using this period to build AI-first design fluency through real personal projects.</p>
						<p class="text-sm text-gray-500 italic">Notable projects: Quiet Signals caregiving app, Portfolio tracker.</p>
					</div>
				</div>

				<!-- 2022-2025 - AT&T -->
				<div class="grid grid-cols-[1fr_1fr_2fr] gap-12 items-start">
					<div>
						<span class="inline-block bg-gray-200 text-gray-700 text-sm px-4 py-2 rounded-full">2022–2025</span>
					</div>
					<div>
						<h3 class="text-lg font-semibold text-gray-900">AT&T</h3>
						<p class="text-gray-500 italic">Design Strategist</p>
					</div>
					<div>
						<p class="text-gray-600 mb-3">Identified opportunities throughout the customer experience to mix business imperatives with a user-centered approach.</p>
						<p class="text-sm text-gray-500 italic">Notable projects: Shopper's Profile, Personalized Shopping, Split Pay, Fiber CI</p>
					</div>
				</div>

				<!-- 2019-2021 - Verizon -->
				<div class="grid grid-cols-[1fr_1fr_2fr] gap-12 items-start">
					<div>
						<span class="inline-block bg-gray-200 text-gray-700 text-sm px-4 py-2 rounded-full">2019–2021</span>
					</div>
					<div>
						<h3 class="text-lg font-semibold text-gray-900">Verizon</h3>
						<p class="text-gray-500 italic">Experience Designer</p>
					</div>
					<div>
						<p class="text-gray-600 mb-3">Conceived and built omnichannel service experiences making the process easier and more secure for 100M+ customers.</p>
						<p class="text-sm text-gray-500 italic">Notable projects: Number Transfer, Port Out Security, Chat/Search Integration</p>
					</div>
				</div>

				<!-- 2016-2018 - Comcast -->
				<div class="grid grid-cols-[1fr_1fr_2fr] gap-12 items-start">
					<div>
						<span class="inline-block bg-gray-200 text-gray-700 text-sm px-4 py-2 rounded-full">2016–2018</span>
					</div>
					<div>
						<h3 class="text-lg font-semibold text-gray-900">Comcast</h3>
						<p class="text-gray-500 italic">Product Designer</p>
					</div>
					<div>
						<p class="text-gray-600 mb-3">Worked on xFi WiFi management app from launch to 10M+ users. Developed key features including profile management and conversational UI.</p>
						<p class="text-sm text-gray-500 italic">Notable projects: Profiles & Devices, Conversational/Voice UI</p>
					</div>
				</div>

				<!-- 2014-2016 - Publicis/Razorfish -->
				<div class="grid grid-cols-[1fr_1fr_2fr] gap-12 items-start">
					<div>
						<span class="inline-block bg-gray-200 text-gray-700 text-sm px-4 py-2 rounded-full">2014–2016</span>
					</div>
					<div>
						<h3 class="text-lg font-semibold text-gray-900">Publicis/Razorfish</h3>
						<p class="text-gray-500 italic">Information Architect</p>
					</div>
					<div>
						<p class="text-gray-600 mb-3">Part of dedicated agency for JPMorgan Chase digital initiatives. Launched early prototypes for digital wallets and mobile payments.</p>
						<p class="text-sm text-gray-500 italic">Notable projects: Freedom Points App, Chase Wallet Prototype, Mobile Marketplace</p>
					</div>
				</div>

				<!-- 2011-2014 - Publicis/Rosetta -->
				<div class="grid grid-cols-[1fr_1fr_2fr] gap-12 items-start">
					<div>
						<span class="inline-block bg-gray-200 text-gray-700 text-sm px-4 py-2 rounded-full">2011–2014</span>
					</div>
					<div>
						<h3 class="text-lg font-semibold text-gray-900">Publicis/Rosetta</h3>
						<p class="text-gray-500 italic">Content Strategist</p>
					</div>
					<div>
						<p class="text-gray-600 mb-3">Specialized in content-first UX design for websites and mobile apps.</p>
						<p class="text-sm text-gray-500 italic">Notable clients: Financial Services (JPMorgan Chase, Fidelity), Consumer Goods (Panasonic, Lenovo, AT&T), and Healthcare (Pfizer, UnitedHealthcare).</p>
					</div>
				</div>

			</div>
		</section>

		<!-- Section: Writings -->
		<div class="border-t border-gray-200 mt-16 mb-12">
			<span class="text-sm text-gray-900 block pt-4">(Writings)</span>
		</div>
		<section id="writings" class="pb-16 border-b border-gray-200">
			<div class="grid grid-cols-2 gap-8">

				<!-- Writing 1 -->
				<a href="#" class="group block">
					<h3 class="text-xl font-normal text-gray-900 mb-1 group-hover:text-gray-500 transition-colors">My Mid-career sabbatical</h3>
					<p class="text-sm text-gray-600">How my thinking about work and life has changed based on recent life events.</p>
				</a>

				<!-- Writing 2 -->
				<a href="#" class="group block">
					<h3 class="text-xl font-normal text-gray-900 mb-1 group-hover:text-gray-500 transition-colors">Human in the loop</h3>
					<p class="text-sm text-gray-600">Riding the technological wave — This feels like the 3rd and most dramatic act in the evolution of the web and Internet</p>
				</a>

			</div>
		</section>

	</main>

	<!-- Contact + Footer -->
	<footer id="contact" class="mt-16">
		<div class="px-8 py-16">
			<div class="flex items-start justify-between gap-12">

				<!-- Left: contact info -->
				<div>
					<h2 class="text-2xl font-bold text-gray-900 mb-6">Working on something complex?<br>Let's think it through together.</h2>
					<a href="mailto:brendanrohan@gmail.com" class="block text-blue-600 hover:underline mb-2">brendanrohan@gmail.com</a>
					<p class="text-gray-500 mb-8">(917) 318-1263</p>
					<div class="flex items-center gap-5">
						<!-- LinkedIn -->
						<a href="https://www.linkedin.com/in/brendanrohan" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-gray-500 hover:text-gray-900 transition-colors">
							<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
								<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
							</svg>
						</a>
						<!-- GitHub -->
						<a href="https://github.com/brendanrohan" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-gray-500 hover:text-gray-900 transition-colors">
							<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
